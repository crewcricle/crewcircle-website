# =============================================================================
# CrewCircle Monorepo — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# For CI/CD: set these as GitHub Actions secrets or Doppler env vars.
# For local dev: `cp .env.example .env.local` then fill values.
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTITY — who is running this setup (CREW CIRCLE PTY LTD)
# -----------------------------------------------------------------------------
CC_EMAIL=                        # prabhat@crewcircle.com.au
CC_FIRST_NAME=                   # Prabhat
CC_LAST_NAME=                    # Singh
CC_COMPANY=                      # CREW CIRCLE PTY LTD
CC_ABN=                          # xx xxx xxx xxx
CC_DOMAIN=                       # crewcircle.com.au
CC_AU_PHONE=                     # +614xxxxxxxx  (mobile, for Twilio OTP)
CC_GITHUB_USERNAME=              # crewcircle-au (or your chosen username)
CC_DOPPLER_MASTER_PROJECT=       # crewcircle-master
CC_SENTRY_ORG=                   # your-sentry-org-slug

# -----------------------------------------------------------------------------
# CREDENTIALS — populated by account-setup/setup.py, then managed by Doppler
# Do not fill these manually. setup.py writes them after each account is created.
# After setup.py completes, these live in Doppler crewcircle-master/prod.
# -----------------------------------------------------------------------------

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_EMAIL=

# GitHub
GITHUB_TOKEN=

# DigitalOcean
DIGITALOCEAN_TOKEN=
DROPLET_IP=
DROPLET_ID=

# Pulumi
PULUMI_ACCESS_TOKEN=

# Supabase (management — not project-level)
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=

# Doppler (bootstrap token — written by setup.py, then self-manages)
DOPPLER_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_GST_RATE_ID=              # set after manually creating 10% GST rate in Stripe dashboard

# Anthropic
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_AU_NUMBER=

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Cloud / GBP
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# Sentry
SENTRY_TOKEN=

# Uptime Robot
UPTIME_ROBOT_API_KEY=

# Infrastructure
BASE_DOMAIN=                     # crewcircle.com.au
