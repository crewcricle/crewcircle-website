# Master environment variables for CrewCircle infrastructure provisioning.
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local.

# GitHub
CC_GITHUB_USERNAME=crewcricle
GITHUB_TOKEN=ghp_xxxxxxxx

# Doppler (master project bootstrap token)
DOPPLER_TOKEN=dp.ct.xxxxxxxx

# Supabase
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
SUPABASE_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cloudflare
CLOUDFLARE_API_TOKEN=xxxxxxxx
CLOUDFLARE_ZONE_ID=xxxxxxxx

# Sentry
SENTRY_TOKEN=sntrys_xxxxxxxx
CC_SENTRY_ORG=crewcircle

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
